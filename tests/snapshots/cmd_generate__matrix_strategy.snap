workflow("CI", {
  on: triggers({ push: ["main"] }),
  jobs(ctx) {
    ctx.job("Test", {
      runs_on: "ubuntu-latest",
      strategy: matrix({
        os: ["ubuntu-latest", "macos-latest"],
        node: ["18", "20"],
