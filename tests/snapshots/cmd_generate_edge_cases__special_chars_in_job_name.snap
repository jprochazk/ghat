--- .github/ghat/workflows/ci.ts ---
workflow("CI", {
  on: triggers({ push: ["main"] }),
  jobs(ctx) {
    const build = ctx.job("Build & Test (Linux)", {
      runs_on: "ubuntu-latest",
      steps() {
        run("cargo build")
        return { result: "ok" }
      }
    })
    ctx.job("Deploy [Staging]", {
      runs_on: "ubuntu-latest",
      needs: [build],
      steps(ctx) {
        run(`echo ${ctx.needs.build__test_linux.outputs.result}`)
      }
    })
  }
})
