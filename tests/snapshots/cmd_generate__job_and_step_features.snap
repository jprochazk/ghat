name: Needs And Outputs
on:
  push:
    branches:
    - main
jobs:
  build_artifacts:
    name: Build Artifacts
    runs-on: ubuntu-latest
    outputs:
      artifact: build.tar.gz
      version: 1.0.0
    steps:
    - id: step_0
      run: cargo build --release
  deploy_to_production:
    name: Deploy To Production
    runs-on: ubuntu-latest
    needs:
    - build_artifacts
    if: ${{ needs.build_artifacts.result == 'success' }}
    env:
      VERSION: ${{ needs.build_artifacts.outputs.version }}
    timeout-minutes: 30
    steps:
    - id: step_0
      run: echo deploying ${{ needs.build_artifacts.outputs.artifact }}
