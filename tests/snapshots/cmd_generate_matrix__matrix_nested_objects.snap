workflow("CI", {
  on: triggers({ push: ["main"] }),
  jobs(ctx) {
    ctx.job("Test", {
      runs_on: "ubuntu-latest",
      strategy: matrix({
        config: [
          { version: 14, env: "staging" },
          { version: 20, env: "production" },
        ],
      }),
      steps(ctx) {
        run(`echo ${ctx.matrix.config.version} ${ctx.matrix.config.env}`)
      }
    })
  }
})
