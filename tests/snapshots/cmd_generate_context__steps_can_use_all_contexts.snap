# Do not edit: this file is generated by `ghat generate`.
name: CI
on:
  push:
    branches:
    - main
jobs:
  test:
    name: Test
    runs-on: ubuntu-latest
    strategy:
      matrix:
        os:
        - ubuntu-latest
    steps:
    - id: step_0
      run: github=${{ github.sha }}
    - id: step_1
      run: runner=${{ runner.os }}
    - id: step_2
      run: env=${{ env.PATH }}
    - id: step_3
      run: vars=${{ vars.MY_VAR }}
    - id: step_4
      run: secrets=${{ secrets.TOKEN }}
    - id: step_5
      run: matrix=${{ matrix.os }}
    - id: step_6
      run: job=${{ job.status }}
    - id: step_7
      run: strategy=${{ strategy.fail_fast }}
