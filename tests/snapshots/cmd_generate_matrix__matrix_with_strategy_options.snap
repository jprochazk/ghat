workflow("CI", {
  on: triggers({ push: ["main"] }),
  jobs(ctx) {
    ctx.job("Test", {
      runs_on: "ubuntu-latest",
      strategy: {
        matrix: matrix({ os: ["ubuntu-latest", "macos-latest"] }),
        fail_fast: false,
        max_parallel: 2,
      },
      steps(ctx) {
        run(`echo ${ctx.matrix.os}`)
      }
    })
  }
})
