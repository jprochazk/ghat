name: Build
on:
  workflow_call:
    inputs:
      save_cache:
        type: boolean
        required: false
        default: 'false'
    outputs:
      artifact_path:
        description: Path to the built artifact
        value: ${{ jobs.compile.outputs.artifact_path }}
jobs:
  compile:
    name: Compile
    runs-on: ubuntu-latest
    outputs:
      artifact_path: ${{ steps.step_0.outputs.path }}
    steps:
    - id: step_0
      run: cargo build --release --cache ${{ inputs.save_cache }}
