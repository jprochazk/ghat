workflow("CI", {
  on: triggers({ push: ["main"] }),
  jobs(ctx) {
    ctx.job("Build", {
      runs_on: "ubuntu-latest",
      steps() {
        uses("actions/checkout", {
          name: "Checkout code",
          if: "github.event_name == 'push'",
          continue_on_error: true,
          timeout_minutes: 5,
        })
        run("cargo build")
      }
    })
  }
})
