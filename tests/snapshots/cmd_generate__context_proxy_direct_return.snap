workflow("CI", {
  on: triggers({ push: ["main"] }),
  jobs(ctx) {
    ctx.job("Test", {
      // Direct return of proxy should produce ${{ matrix.runner }}, not ${{ matrix.runner.toJSON }}
      runs_on: (ctx) => ctx.matrix.runner,
      strategy: matrix({
        runner: ["ubuntu-latest", "macos-latest"],
      }),
      steps(ctx) {
        run("echo hello")
      }
    })
  }
})
