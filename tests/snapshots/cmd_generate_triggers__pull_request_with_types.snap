workflow("PR", {
  on: triggers({
    pull_request: {
      branches: ["main"],
      types: ["opened", "synchronize", "reopened"],
    }
  }),
  jobs(ctx) {
    ctx.job("Check", {
      runs_on: "ubuntu-latest",
      steps() { run("cargo check") }
    })
  }
})
