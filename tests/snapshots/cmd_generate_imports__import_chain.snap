import { MAIN_BRANCH } from "./_constants.ts"
import { buildJob } from "./_helpers.ts"

workflow("CI", {
  on: triggers({ push: [MAIN_BRANCH] }),
  jobs(ctx) {
    buildJob(ctx)
  }
})
