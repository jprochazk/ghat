export const ci_triggers = triggers({
  push: ["main"],
  pull_request: { branches: ["main"] },
})
--- .github/ghat/workflows/build.ts ---
import { ci_triggers } from "./_triggers.ts"

workflow("Build", {
  on: ci_triggers,
  jobs(ctx) {
    ctx.job("Build", {
      runs_on: "ubuntu-latest",
      steps() { run("cargo build") }
    })
  }
})
