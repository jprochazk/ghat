workflow("PR Target", {
  on: triggers({
    pull_request_target: {
      branches: ["main"],
      types: ["opened", "labeled"],
    }
  }),
  jobs(ctx) {
    ctx.job("Label Check", {
      runs_on: "ubuntu-latest",
      steps() { run("echo checking labels") }
    })
  }
})
