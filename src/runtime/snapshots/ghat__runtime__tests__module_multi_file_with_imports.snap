=== /workflows/_helpers.ts ===
export function rustSteps(): object[] {
    return [
        { run: "rustup show" },
        { run: "cargo test" },
    ];
}
=== /workflows/ci.ts ===
import { rustSteps } from "./_helpers.ts";

__define_workflow("CI", {
    name: "CI",
    on: { push: { branches: ["main"] } },
    jobs: {
        test: {
            name: "test",
            "runs-on": "ubuntu-latest",
            steps: rustSteps()
        }
    }
});
