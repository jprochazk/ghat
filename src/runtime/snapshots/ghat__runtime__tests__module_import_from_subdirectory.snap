=== /workflows/lib/steps.js ===
export function checkStep() { return { run: "cargo check" }; }
=== /workflows/ci.js ===
import { checkStep } from "./lib/steps.js";

__define_workflow("CI", {
    name: "CI",
    on: { push: { branches: ["main"] } },
    jobs: {
        check: {
            name: "check",
            "runs-on": "ubuntu-latest",
            steps: [checkStep()]
        }
    }
});
